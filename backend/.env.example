# Copy this file to .env and fill in real values. Never commit .env.

# Server
PORT=5000
NODE_ENV=development

# Frontend origin allowed by CORS (comma-separated for multiple)
CLIENT_ORIGIN=http://localhost:5173

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/taskflow?retryWrites=true&w=majority

# JWT: a long random secret. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Groq (added when AI features land). Get a free key at https://console.groq.com
GROQ_API_KEY=

# --- Integrations (all optional; an action only needs the vars it uses) ---

# Slack incoming webhook URL. Create one at https://api.slack.com/messaging/webhooks
# A rule's slack action can also carry its own webhookUrl in params to override this.
SLACK_WEBHOOK_URL=

# Google Sheets (service account, free). See backend/README.md for setup.
# The service account email must be granted edit access to the target sheet.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Private key from the service account JSON. Keep the literal \n escapes; the code un-escapes them.
GOOGLE_PRIVATE_KEY=
# Default spreadsheet id (the long id in the sheet URL). A rule can override via params.spreadsheetId.
GOOGLE_SHEET_ID=

# Email via SMTP (e.g. a free Gmail App Password, or Ethereal for testing).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Default "from" address for outgoing mail.
MAIL_FROM="TaskFlow <no-reply@taskflow.local>"
